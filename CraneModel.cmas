                                  "LocalValue": "STRUCTUREDTEXT"
                                }
                              ],
                              [
                                "Cost",
                                {
                                  "Name": "Cost",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "The cost to execute the process plan, can be used for optimisation.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[INHERITANCE]",
                                  "LocalValue": "0"
                                }
                              ],
                              [
                                "PostAction",
                                {
                                  "Name": "PostAction",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "An action to be execute after the process plan is done.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[INHERITANCE]",
                                  "LocalValue": "TRANSFERED"
                                }
                              ],
                              [
                                "TargetType",
                                {
                                  "Name": "TargetType",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "A target type of the process plan.",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[STRINGEDIT, MODELLING]",
                                  "LocalValue": ""
                                }
                              ],
                              [
                                "Actions",
                                {
                                  "Name": "Actions",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                                  "Description": "Process plan actions",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[TEXTEDITOR]",
                                  "LocalValue": "Program transportPart;\n\nvar constant SAFE_HEIGHT:\u003d150 : integer;\nvar busy:boolean;\nvar picStep:\u003d0:integer;\n\nprocedure onDeploy;\nbegin\n    busy :\u003d false;\n    picStep :\u003d 0;\n    agent.vacuum :\u003d 0;\nend.\n\nfunction isMoving(): boolean;\nbegin\n    isMoving :\u003d NOT ((agent.setX \u003d agent.atX) AND (agent.setY \u003d agent.atY));\nend.\n\nfunction isAtPosition(x,y:integer): boolean;\nbegin\n    isAtPosition :\u003d (agent.atX \u003d x) AND (agent.atY \u003d y);\nend.\n\nfunction isAtCommand(): boolean;\nbegin\n    isAtCommand :\u003d (agent.atX \u003d agent.setX) AND (agent.atY \u003d agent.setY);\nend.\n\nfunction isBusy(): boolean;\nbegin\n    isBusy :\u003d\n        busy\n        or picStep \u003c\u003e 0\n        or isMoving();\nend.\n\nfunction onNegotiate(Planning : boolean): integer;\nbegin\n    if isBusy() then\n        onNegotiate :\u003d -1;\n    else\n        onNegotiate :\u003d this.cost;\nend.\n\nprocedure moveTo(x,y:integer);\nbegin\n    agent.setX :\u003d x;\n    agent.setY :\u003d y;\n    agent.targetX :\u003d x;\n    agent.targetY :\u003d y;\nend.\n\nfunction picorplace(posX, posY : integer; vacuum:boolean) : boolean;\nbegin\n    picorplace :\u003d false;\n\n    case picStep of\n\n    0:\n        begin\n            if agent.atY \u003c\u003e SAFE_HEIGHT then begin\n                moveTo(agent.atX, SAFE_HEIGHT);\n                picStep :\u003d 10;\n            end;\n            else\n                picStep :\u003d 20;\n        end;\n\n    10:\n        begin\n            if isAtCommand() then\n                picStep :\u003d 20;\n        end;\n\n    20:\n        begin\n            if agent.atX \u003c\u003e posX then begin\n                moveTo(posX, SAFE_HEIGHT);\n                picStep :\u003d 30;\n            end;\n            else\n                picStep :\u003d 40;\n        end;\n\n    30:\n        begin\n            if isAtCommand() then\n                picStep :\u003d 40;\n        end;\n\n    40:\n        begin\n            if agent.atY \u003c\u003e posY then begin\n                moveTo(posX, posY);\n                picStep :\u003d 50;\n            end;\n            else\n                picStep :\u003d 60;\n        end;\n\n    50:\n        begin\n            if isAtCommand() then\n                picStep :\u003d 60;\n        end;\n\n    60:\n        begin\n            agent.vacuum :\u003d booleantoint(vacuum);\n            picStep :\u003d 70;\n        end;\n\n    70:\n        begin\n            if agent.atY \u003c\u003e SAFE_HEIGHT then begin\n                moveTo(agent.atX, SAFE_HEIGHT);\n                picStep :\u003d 80;\n            end;\n            else\n                picStep :\u003d 90;\n        end;\n\n    80:\n        begin\n            if isAtCommand() then\n                picStep :\u003d 90;\n        end;\n\n    90:\n        begin\n            picStep :\u003d 0;\n            picorplace :\u003d true;\n        end;\n\n    else:\n        begin\n            picStep :\u003d 0;\n            busy :\u003d false;\n            error \u0027wrong transport state: \u0027 + inttostring(picStep);\n        end;\n    end;\nend.\n\nfunction onRun() : integer;\nbegin\n    busy :\u003d true;\n    onRun :\u003d processplan.running;\n\n    writeln(\n        \u0027transport step\u003d\u0027, interface.Specialisation.step,\n        \u0027 picStep\u003d\u0027, picStep,\n        \u0027 at\u003d(\u0027, agent.atX, \u0027,\u0027, agent.atY,\n        \u0027) set\u003d(\u0027, agent.setX, \u0027,\u0027, agent.setY,\n        \u0027) vacuum\u003d\u0027, agent.vacuum\n    );\n\n    if interface.Specialisation.step \u003d 1 then begin\n\n        if picorplace(\n            interface.Specialisation.FromLocation.x,\n            interface.Specialisation.FromLocation.y,\n            true\n        ) then begin\n            busy :\u003d false;\n            onRun :\u003d processplan.done;\n        end;\n\n    end;\n    else if interface.Specialisation.step \u003d 2 then begin\n\n        if picorplace(\n            interface.Specialisation.ToLocation.x,\n            interface.Specialisation.ToLocation.y,\n            false\n        ) then begin\n            busy :\u003d false;\n            onRun :\u003d processplan.done;\n        end;\n\n    end;\n    else begin\n        busy :\u003d false;\n        picStep :\u003d 0;\n        onRun :\u003d processplan.failed;\n    end;\nend."
                                }
                              ]
                            ],
