                  ],
                  [
                    "AutoDeploy",
                    {
                      "Name": "AutoDeploy",
                      "ClassName": "cmas.ontology.agents.Agent",
                      "Description": "If true the agent will be deployed at run",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[INHERITANCE, HIDEBASIC]",
                      "LocalValue": "true"
                    }
                  ],
                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.agents.AgentAction",
                      "Description": "User defined actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR, MODELLING]",
                      "LocalValue": "program Source1;\n\nvar newPart:boolean;\nvar waitingForPickup:boolean;\nvar retryCount:\u003d0:integer;\nvar constant MAX_RETRIES:\u003d100:integer;\n\nfunction process1Free() : boolean;\nbegin\n    process1Free :\u003d not agent.p1sensor and not agent.p1running;\nend.\n\nfunction process2Occupied() : boolean;\nbegin\n    process2Occupied :\u003d agent.p2sensor or agent.p2running;\nend.\n\nfunction craneIdle() : boolean;\nbegin\n    craneIdle :\u003d\n        (agent.atX \u003d agent.setX)\n        and (agent.atY \u003d agent.setY)\n        and (agent.vacuum \u003d 0);\nend.\n\nfunction safeToDeploy() : boolean;\nbegin\n    safeToDeploy :\u003d\n        agent.sensor1\n        and not newPart\n        and not waitingForPickup\n        and process1Free()\n        and not process2Occupied()\n        and craneIdle();\nend.\n\nfunction Deploy(Name:string) : boolean;\nbegin\n    Deploy :\u003d false;\n\n    if deployandattach(Name) then begin\n        writeln(Name + \u0027 deployed from Source1\u0027);\n        Deploy :\u003d true;\n    end;\n    else begin\n        writeln(\u0027Source1 failed to deploy \u0027 + Name + \u0027, will retry...\u0027);\n        retryCount :\u003d retryCount + 1;\n    end;\nend.\n\nprocedure onDeploy;\nbegin\n    newPart :\u003d false;\n    waitingForPickup :\u003d false;\n    retryCount :\u003d 0;\nend.\n\nprocedure Running;\nbegin\n      //If Source1 becomes empty, the previous ProductA has been picked up.\n      //Allow the next ProductA later.\n\n    if not agent.sensor1 then begin\n        newPart :\u003d false;\n        waitingForPickup :\u003d false;\n        retryCount :\u003d 0;\n    end;\n\n      //Source1 has a generated part waiting.\n      //Only attach/deploy a ProductA agent if Process1 and crane are ready.\n  \n    else if safeToDeploy() then begin\n        if Deploy(\u0027ProductA\u0027) then begin\n            newPart :\u003d true;\n            waitingForPickup :\u003d true;\n            retryCount :\u003d 0;\n        end;\n    end;\n\n      //Error handling: avoid infinite retry/livelock.\n\n    else if agent.sensor1 and not newPart then begin\n        retryCount :\u003d retryCount + 1;\n\n        if retryCount \u003e MAX_RETRIES then begin\n            writeln(\u0027WARNING Source1: ProductA waiting too long. Process1 or crane may be blocked.\u0027);\n            retryCount :\u003d 0;\n        end;\n    end;\n\n    Sleep(50);\nend."
                    }
