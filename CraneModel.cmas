                              [
                                "Actions",
                                {
                                  "Name": "Actions",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlanStructuredText",
                                  "Description": "Process plan actions",
                                  "CanInherit": true,
                                  "Override": true,
                                  "ReadOnly": false,
                                  "ParentID": "",
                                  "PropertyType": "[TEXTEDITOR]",
                                  "LocalValue": "Program runProcess2;\n\nvar processState:\u003d0: integer;\n\nprocedure onDeploy;\nbegin\n    processState :\u003d 0;\n    agent.startProcess :\u003d false;\nend.\n\nfunction onNegotiate(Planning : boolean): integer;\nbegin\n    if agent.processRunning or processState \u003c\u003e 0 then\n        onNegotiate :\u003d -1;\n    else\n        onNegotiate :\u003d this.cost;\nend.\n\nfunction onRun() : integer;\nbegin\n    onRun :\u003d processplan.running;\n    sleep(50);\n\n    case processState of\n\n    0:\n        begin\n            writeln(\u0027Start to run \u0027 + agent.name);\n\n            if agent.proximitySensor and not agent.processRunning then begin\n                agent.startProcess :\u003d true;\n                processState :\u003d 10;\n            end;\n            else\n                onRun :\u003d processplan.failed;\n        end;\n\n    10:\n        if agent.processRunning then begin\n            agent.startProcess :\u003d false;\n            processState :\u003d 20;\n        end;\n\n    20:\n        if not agent.processRunning then\n            processState :\u003d 30;\n\n    30:\n        begin\n            processState :\u003d 0;\n            agent.startProcess :\u003d false;\n            writeln(agent.name + \u0027 is done\u0027);\n            onRun :\u003d processplan.done;\n        end;\n\n    else:\n        begin\n            processState :\u003d 0;\n            agent.startProcess :\u003d false;\n            onRun :\u003d processplan.failed;\n        end;\n    end;\nend."
                                }
                              ]
