                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.agents.AgentAction",
                      "Description": "User defined actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR, MODELLING]",
                      "LocalValue": "program Crane;\n\nvar oldx, oldy : integer;\n\nprocedure onRun;\nbegin\n    agent.targetX:\u003dagent.atX;\n    agent.targetY:\u003dagent.atY;\n    \n    oldx:\u003dagent.targetX;\n    oldy:\u003dagent.targetY;    \nend.\n\nprocedure running;\nbegin\n    if oldx\u003c\u003eagent.targetX then begin\n        agent.setX:\u003dagent.targetX;\n        oldx:\u003dagent.targetX;\n    end;\n\n    if oldy\u003c\u003eagent.targetY then begin\n        agent.setY:\u003dagent.targetY;\n        oldy:\u003dagent.targetY;\n    end;\n\n    sleep(50);\nend."
                    }
