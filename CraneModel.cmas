                                }
                              ],
                              [
                                "ProcessPlanType",
                                {
                                  "Name": "ProcessPlanType",
                                  "ClassName": "cmas.ontology.processplan.ProcessPlan",
                                  "Description": "Type of process plan",
                                  "CanInherit": false,
                                  "Override": true,
                                  "ReadOnly": true,
                                  "ParentID": "",
