                  [
                    "AutoDeploy",
                    {
                      "Name": "AutoDeploy",
                      "ClassName": "cmas.ontology.agents.Agent",
                      "Description": "If true the agent will be deployed at run",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[INHERITANCE, HIDEBASIC]",
                      "LocalValue": "true"
                    }
                  ],
                  [
                    "Actions",
                    {
                      "Name": "Actions",
                      "ClassName": "cmas.ontology.agents.AgentAction",
                      "Description": "User defined actions",
                      "CanInherit": true,
                      "Override": true,
                      "ReadOnly": false,
                      "ParentID": "",
                      "PropertyType": "[TEXTEDITOR, MODELLING]",
                      "LocalValue": "program Source2;\n\nvar newPart:boolean;\nvar waitingForPickup:boolean;\nvar retryCount:\u003d0:integer;\nvar constant MAX_RETRIES:\u003d100:integer;\n\n\nfunction process2Free() : boolean;\nbegin\n    process2Free :\u003d not agent.p2sensor and not agent.p2running;\nend.\n\nfunction safeToDeploy() : boolean;\nbegin\n    safeToDeploy :\u003d\n        agent.sensor2\n        and not newPart\n        and not waitingForPickup\n        and process2Free();\nend.\n\nfunction Deploy(Name:string) : boolean;\nbegin\n    Deploy :\u003d false;\n\n    if deployandattach(Name) then begin\n        writeln(Name + \u0027 deployed\u0027);\n        Deploy :\u003d true;\n    end;\n    else\n        writeln(\u0027Source2 not ready to attach \u0027 + Name + \u0027, retrying...\u0027);\nend.\n\nprocedure onDeploy;\nbegin\n    newPart :\u003d false;\nend.\n\nprocedure Running;\nbegin\n    if not agent.sensor2 then\n        newPart :\u003d false;\n    else if agent.sensor2\n        and not newPart\n        and process2Free()\n    then begin\n        if Deploy(\u0027ProductB\u0027) then\n            newPart :\u003d true;\n    end;\n\n    Sleep(50);\nend."
                    }
                  ],
